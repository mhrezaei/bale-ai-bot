# Bot Configuration
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ
ADMIN_TELEGRAM_ID=123456789

# Database Configuration (Matching docker-compose port)
MONGO_URI=mongodb://127.0.0.1:27018/maskhare_bazi

# X-UI Configuration
XUI_URL=http://127.0.0.1:2053
XUI_USERNAME=admin
XUI_PASSWORD=admin_password

# SOCKS5 Proxy Configuration (For Telegram API)
PROXY_HOST=192.168.1.x
PROXY_PORT=10800
PROXY_USERNAME=proxy_user
PROXY_PASSWORD=proxy_pass

# Server Configuration for VLESS Links
SERVER_IP_OR_DOMAIN=your.domain.com
SERVER_PORT=443
SERVER_SNI=yahoo.com
SERVER_PBK=your_public_key
SERVER_SID=your_short_id